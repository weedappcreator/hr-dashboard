{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder",
  "small_model": "ollama/llama3.2",
  "permission": {
    "skill": {
      "*": "allow"
    },
    "bash": "allow",
    "edit": "allow",
    "write": "allow"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.2": {
          "name": "Llama 3.2"
        },
        "codellama": {
          "name": "Code Llama"
        },
        "qwen2.5-coder": {
          "name": "Qwen 2.5 Coder"
        },
        "mistral": {
          "name": "Mistral"
        }
      }
    }
  },
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=pbajbvzjadplzkxfejbu&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching",
      "enabled": true
    }
  }
}
